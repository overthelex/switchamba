class SplashScreen(Adw.Window):
    """Business-style splash screen shown on application launch."""

    def __init__(self, app, on_done=None):
        super().__init__(
            application=app,
            title="Switchamba",
            default_width=520,
            default_height=480,
            resizable=False,
            decorated=False,
            modal=True,
        )
        self._on_done = on_done

        # Load CSS
        css_provider = Gtk.CssProvider()
        css_provider.load_from_string(SPLASH_CSS)
        Gtk.StyleContext.add_provider_for_display(
            self.get_display(), css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        self._build_ui()

        # Auto-close after 3 seconds
        GLib.timeout_add(3000, self._close_splash)

        # Also allow click to dismiss
        click = Gtk.GestureClick()
        click.connect("released", lambda *_: self._close_splash())
        self.add_controller(click)

    def _build_ui(self):
        overlay = Gtk.Overlay()

        # Background
        bg = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, vexpand=True, hexpand=True)
        bg.add_css_class("splash-window")
        overlay.set_child(bg)

        # Content
        content = Gtk.Box(
            orientation=Gtk.Orientation.VERTICAL,
            spacing=0,
            halign=Gtk.Align.CENTER,
            valign=Gtk.Align.CENTER,
            margin_start=40,
            margin_end=40,
        )

        # Logo
        logo_paths = [
            "/usr/share/switchamba/icon-transparent.png",
            os.path.join(os.path.dirname(os.path.abspath(__file__)), "icon-transparent.png"),
        ]
        logo_path = None
        for p in logo_paths:
            if os.path.exists(p):
                logo_path = p
                break

        if logo_path:
            logo = Gtk.Picture.new_for_filename(logo_path)
            logo.set_size_request(200, 180)
            logo.set_halign(Gtk.Align.CENTER)
            logo.set_content_fit(Gtk.ContentFit.CONTAIN)
            logo.set_margin_bottom(12)
            content.append(logo)
        else:
            # Fallback: text title
            title = Gtk.Label(label="SWITCHAMBA")
            title.add_css_class("splash-title")
            content.append(title)

        # Subtitle
        subtitle = Gtk.Label(label="LAYOUT INTELLIGENCE")
        subtitle.add_css_class("splash-subtitle")
        subtitle.set_margin_top(4)
        content.append(subtitle)

        # Divider
        divider = Gtk.Separator()
        divider.add_css_class("splash-divider")
        divider.set_margin_top(24)
        divider.set_margin_bottom(24)
        divider.set_size_request(200, -1)
        divider.set_halign(Gtk.Align.CENTER)
        content.append(divider)

        # Authors
        authors_label = Gtk.Label(label="CREATED BY")
        authors_label.add_css_class("splash-version")
        authors_label.set_margin_bottom(10)
        content.append(authors_label)

        author1 = Gtk.Label(label="Vladimir Obcharov")
        author1.add_css_class("splash-author-name")
        content.append(author1)

        ampersand = Gtk.Label(label="&")
        ampersand.add_css_class("splash-authors")
        ampersand.set_margin_top(4)
        ampersand.set_margin_bottom(4)
        content.append(ampersand)

        author2 = Gtk.Label(label="Claude Code")
        author2.add_css_class("splash-author-name")
        content.append(author2)

        # Version + copyright
        version_box = Gtk.Box(
            orientation=Gtk.Orientation.VERTICAL,
            spacing=4,
            halign=Gtk.Align.CENTER,
            margin_top=28,
        )
        version = Gtk.Label(label="VERSION 0.1.0")
