#!/usr/bin/env python3
"""Switchamba Setup Wizard & Settings UI.

GTK4/Adwaita application for initial setup and configuration management.
Launched automatically after package installation or from the app menu.
"""

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')

import grp
import os
import subprocess
import sys
from pathlib import Path

from gi.repository import Adw, Gio, GLib, Gtk, Pango


CONFIG_DIR = Path.home() / ".config" / "switchamba"
CONFIG_FILE = CONFIG_DIR / "config.yaml"
SERVICE_NAME = "switchamba.service"
EXTENSION_UUID = "switchamba@vovkes"


def is_in_input_group() -> bool:
    try:
        input_gid = grp.getgrnam("input").gr_gid
        return input_gid in os.getgroups()
    except KeyError:
        return False


def add_to_input_group() -> bool:
    try:
        result = subprocess.run(
            ["pkexec", "usermod", "-aG", "input", os.getlogin()],
            capture_output=True, text=True, timeout=60,
        )
        return result.returncode == 0
    except Exception:
        return False


def is_extension_enabled() -> bool:
    try:
        result = subprocess.run(
            ["gnome-extensions", "info", EXTENSION_UUID],
            capture_output=True, text=True, timeout=5,
        )
        return "ENABLED" in result.stdout
    except Exception:
        return False


def enable_extension() -> bool:
    try:
        result = subprocess.run(
            ["gnome-extensions", "enable", EXTENSION_UUID],
            capture_output=True, text=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def is_service_enabled() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "is-enabled", SERVICE_NAME],
            capture_output=True, text=True, timeout=5,
        )
        return result.stdout.strip() == "enabled"
    except Exception:
        return False


def is_service_running() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "is-active", SERVICE_NAME],
            capture_output=True, text=True, timeout=5,
        )
        return result.stdout.strip() == "active"
    except Exception:
        return False


def enable_and_start_service() -> bool:
    try:
        subprocess.run(
            ["systemctl", "--user", "daemon-reload"],
            capture_output=True, timeout=5,
        )
        subprocess.run(
            ["systemctl", "--user", "enable", SERVICE_NAME],
            capture_output=True, timeout=5,
        )
        result = subprocess.run(
            ["systemctl", "--user", "start", SERVICE_NAME],
            capture_output=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def stop_service() -> bool:
    try:
        result = subprocess.run(
            ["systemctl", "--user", "stop", SERVICE_NAME],
            capture_output=True, timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def load_config() -> dict:
    if not CONFIG_FILE.exists():
        return {}
    try:
        import yaml
        with open(CONFIG_FILE) as f:
            return yaml.safe_load(f) or {}
    except Exception:
        return {}


def save_config(data: dict) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    try:
        import yaml
        with open(CONFIG_FILE, "w") as f:
            yaml.dump(data, f, default_flow_style=False, allow_unicode=True)
    except Exception as e:
        print(f"Error saving config: {e}", file=sys.stderr)


